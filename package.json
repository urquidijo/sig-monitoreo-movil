    "expo-camera": "~56.0.8",
    "expo-device": "~56.0.4",
    "expo-location": "~56.0.19",
    "expo-notifications": "~56.0.19",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-webview": "13.16.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "set \"EXPO_OFFLINE=1\" && expo start",
    "start:cable": "set \"EXPO_OFFLINE=1\" && set \"REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1\" && expo start",
    "start:lan": "set \"EXPO_OFFLINE=1\" && set \"REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.13\" && expo start",
